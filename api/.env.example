# GuardRail AI - Environment Configuration

# Server
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:3000

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2000

# AWS Configuration (for storage only)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# DynamoDB
DYNAMODB_TABLE=GuardRailSessions
EVENTS_TABLE=GuardRailEvents

# S3
S3_BUCKET=guardrail-sessions

# CloudWatch
LOG_GROUP=/guardrail-ai/public

# Rate Limiting
RATE_LIMIT=50

# Security
SESSION_TTL_HOURS=24
MAX_FILE_SIZE_MB=1

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_TOKEN=your_github_token

# Notifications (AWS SES + Slack)
SES_FROM_EMAIL=alerts@yourdomain.com
ALERT_EMAIL=security-team@yourdomain.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
